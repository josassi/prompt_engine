// Database Markup Language (DBML) for Prompt Engine
// Use https://dbdiagram.io to visualize

Project PromptEngine {
  database_type: 'PostgreSQL'
  Note: 'Data model for handling health service nudges, prompts, and notifications.'
}

// -----------------------------------------------------------------------------
// EXTERNAL DATA (Read-Only Sources for Segmentation)
// -----------------------------------------------------------------------------

Table clinical_diagnosis {
  person_id uuid [ref: > master_person.id]
  icd_code varchar [note: "Standard ICD-10 code"]
  diagnosis_date date
  status varchar [note: "active, resolved"]
}

Table lab_result {
  person_id uuid [ref: > master_person.id]
  loinc_code varchar [note: "Standard LOINC code"]
  test_name varchar
  value_numeric float
  unit varchar
  test_date date
}

Table medication_prescription {
  person_id uuid [ref: > master_person.id]
  drug_code varchar [note: "RxNorm or ATC code"]
  drug_name varchar
  start_date date
  end_date date
  is_active boolean
}

Table insurance_coverage {
  person_id uuid [ref: > master_person.id]
  plan_name varchar
  benefit_code varchar [note: "Code defining coverage benefits"]
  coverage_start date
  coverage_end date
}

Table insurance_claim {
  id uuid [pk]
  person_id uuid [ref: > master_person.id]
  claim_date date
  provider_id varchar
  total_amount decimal
  status varchar [note: "paid, pending, denied"]
}

Table claim_line_item {
  claim_id uuid [ref: > insurance_claim.id]
  procedure_code varchar [note: "CPT or HCPCS code"]
  diagnosis_code varchar [note: "ICD code associated with line item"]
  benefit_code varchar
  service_date date
}

Table hospital_encounter {
  id uuid [pk]
  person_id uuid [ref: > master_person.id]
  facility_id varchar
  admission_date timestamp
  discharge_date timestamp
  encounter_type varchar [note: "inpatient, surgery, er"]
  drg_code varchar [note: "Diagnosis Related Group"]
  primary_procedure_code varchar
  
  Note: "Covers surgeries, hospitalizations, and ER visits."
}

Table vaccination_record {
  person_id uuid [ref: > master_person.id]
  vaccine_code varchar [note: "CVX or CPT code"]
  vaccine_name varchar
  administered_date date
  status varchar
}

Table appointment_history {
  person_id uuid [ref: > master_person.id]
  specialty varchar [note: "Cardiology, GP, etc."]
  provider_id varchar
  visit_date date
  status varchar [note: "completed, no-show, scheduled"]
}

Table risk_score {
  person_id uuid [ref: > master_person.id]
  model_name varchar [note: "e.g., 'Readmission Risk', 'Diabetes Risk'"]
  score_value float
  calculated_at date
}

Table social_determinants {
  person_id uuid [ref: > master_person.id]
  category varchar [note: "Transportation, Housing, Food Security"]
  status varchar [note: "stable, at-risk, crisis"]
  assessed_date date
}

// -----------------------------------------------------------------------------
// INCOMING SIGNALS (Event Triggers)
// -----------------------------------------------------------------------------

Table clinical_recommendation {
  id uuid [pk]
  person_id uuid [ref: > master_person.id]
  recommendation_type varchar [note: "e.g. 'cardio_review_6m'"]
  
  // The specific context for THIS recommendation
  source_doctor_name varchar
  visit_date date
  recommended_action_date date
  
  processed boolean [default: false]
  created_at timestamp
  
  Note: "Signals extracted from clinical notes/events to trigger nudges."
}

// -----------------------------------------------------------------------------
// MODULE 1: CUSTOMER DATA & CONSENT (The Foundation)
// -----------------------------------------------------------------------------

Table master_person {
  id uuid [pk, unique, note: "Unique identifier for the customer"]
  first_name varchar
  last_name varchar
  date_of_birth date
  gender varchar
  email varchar
  phone varchar
  // Other PII and clinical summary fields used for segmentation
  last_checkup_date date
  has_asthma boolean
  created_at timestamp
  
  Note: "The central customer table. In reality, segmentation might query this + clinical tables."
}

Enum channel_type {
  email
  push_notification
  sms
  in_app_message
}

Table channel_consent {
  person_id uuid [ref: > master_person.id]
  channel channel_type
  is_consented boolean [default: false]
  updated_at timestamp
  
  indexes {
    (person_id, channel) [unique]
  }
  Note: "Manages opt-in/opt-out per channel."
}

// -----------------------------------------------------------------------------
// MODULE 2: PROMPT CREATION & SEGMENTATION (Marketing / Configuration)
// -----------------------------------------------------------------------------

Enum segment_type {
  library [note: "Reusable Persona (e.g. 'Diabetics')"]
  campaign_ad_hoc [note: "One-off filter specific to a campaign. Hidden from main library."]
  goal [note: "Defines a success criteria (e.g. 'Completed Screening')"]
}

Table segment {
  id integer [pk, increment]
  name varchar
  type segment_type [default: 'library']
  description text
  logic_expression varchar [note: "Boolean logic using criteria labels. e.g. '(A AND B) OR C'. If null, defaults to ALL AND."]
  created_by varchar
  created_at timestamp
  
  Note: "Represents a 'Persona' or target audience. Can be a reusable Library item, a hidden Campaign Ad-Hoc filter, or a Goal."
}

// The building blocks for the "Dynamic SQL"
// Example: Field='age', Operator='>', Value='45', Label='A'
Table segment_criteria {
  id integer [pk, increment]
  segment_id integer [ref: > segment.id]
  label varchar [note: "Reference label for logic_expression (e.g. 'A')"]
  table_name varchar [default: 'master_person', note: "Table to query (e.g. master_person, clinical_data)"]
  field_name varchar [note: "Column name in the specified table"]
  operator varchar [note: "e.g., =, >, <, IN, IS_NULL"]
  value varchar [note: "The threshold value"]
  
  // For Composition (Nested Segments)
  child_segment_id integer [ref: > segment.id, note: "If set, this criteria represents membership in another Segment"]
  
  Note: "Stores the rules used to generate the dynamic SQL for targeting."
}

Enum nudge_category {
  service [note: "Transactional, Mandatory (e.g., Appointment confirmed)"]
  marketing [note: "Promotional, Optional (e.g., Screening reminder)"]
  educational
}

Enum nudge_priority {
  critical
  high
  normal
  low
}

Enum trigger_type {
  segment_membership [note: "Standard: User enters a Persona (e.g. Diabetics)"]
  event_trigger [note: "Transactional: Reacts to a specific signal (e.g. Recommendation)"]
}

// Defines "What" we are sending
Table nudge_definition {
  id integer [pk, increment]
  name varchar [unique]
  category nudge_category
  default_priority nudge_priority
  validity_duration interval [note: "How long the nudge is valid before expiring"]

  // Trigger Logic
  trigger_type trigger_type [default: 'segment_membership']
  trigger_event_type varchar [note: "If event_trigger, matches clinical_recommendation.type"]
  
  // Goal / Action Tracking
  goal_segment_id integer [ref: > segment.id, note: "The condition that marks this nudge as successful/completed"]
  goal_completion_window interval [note: "Time given to complete action before reminder"]
  
  Note: "Catalog of available nudges (e.g., 'Flu Shot Reminder', 'Cardiologist Referral')."
}

// Defines the Workflow Sequence (Initial -> Reminder 1 -> Reminder 2)
Table nudge_step {
  id integer [pk, increment]
  nudge_definition_id integer [ref: > nudge_definition.id]
  step_order integer [note: "1=Initial, 2=Reminder 1, 3=Reminder 2..."]
  delay_interval interval [note: "Time to wait after the PREVIOUS step (0 for step 1)"]
  channel channel_type [note: "Channel for this specific step"]
  
  indexes {
    (nudge_definition_id, step_order) [unique]
  }
  Note: "A step in the Nudge Workflow."
}

Table message_template {
  id integer [pk, increment]
  nudge_step_id integer [ref: > nudge_step.id]
  experiment_group_id integer [ref: > experiment_group.id, note: "Nullable. If set, this content is for a specific A/B variant."]
  subject_line varchar
  body_content text [note: "Supports placeholders like {{first_name}}"]
  
  indexes {
    (nudge_step_id, experiment_group_id) [unique]
  }
  Note: "Content for a specific Step. Can be Default or Variant-specific."
}

// -----------------------------------------------------------------------------
// MODULE 2b: DATA CONTEXT (Dynamic Variables)
// -----------------------------------------------------------------------------

Enum source_lookup_type {
  trigger_event [note: "Use the data from the clinical_recommendation that triggered this"]
  master_person [note: "Directly from the person profile"]
  latest_history [note: "The most recent past record (e.g. Last Lab Result)"]
  upcoming_event [note: "The next future record (e.g. Next Appointment)"]
}

Table nudge_data_source {
  id integer [pk, increment]
  nudge_definition_id integer [ref: > nudge_definition.id]
  alias varchar [note: "Internal name to reference this source (e.g. 'target_visit')"]
  
  lookup_type source_lookup_type
  table_name varchar [note: "e.g. 'appointment_history'"]
  
  // Filtering & Selection Logic (for Database Lookups)
  filter_criteria_json jsonb [note: "e.g. {'specialty': 'Cardiology', 'status': 'completed'}"]
  date_column varchar [note: "Column used for sorting/finding latest (e.g. 'visit_date')"]
  
  Note: "Defines a specific record to fetch data from (e.g. 'The Last Cardiology Visit')."
}

Table template_variable {
  id integer [pk, increment]
  nudge_definition_id integer [ref: > nudge_definition.id]
  name varchar [note: "The placeholder name used in body_content (e.g. 'visit_date')"]
  
  nudge_data_source_id integer [ref: > nudge_data_source.id, note: "Which source does this variable come from?"]
  column_name varchar [note: "e.g. 'visit_date' or 'source_doctor_name'"]
  
  Note: "Resolves {{name}} to a specific value from a defined Data Source."
}

Table campaign {
  id integer [pk, increment]
  name varchar
  segment_id integer [ref: > segment.id, note: "Points to the Target Audience (Library or Ad-Hoc)"]
  nudge_definition_id integer [ref: > nudge_definition.id, note: "What to send"]
  start_date timestamp
  end_date timestamp
  is_active boolean
  schedule_cron varchar [note: "Frequency of the campaign run (e.g., Daily at 9am)"]
  created_by varchar
  created_at timestamp
  
  Note: "Binds a Segment to a Nudge."
}

// -----------------------------------------------------------------------------
// MODULE 2b: EXPERIMENTATION (A/B Testing)
// -----------------------------------------------------------------------------

Enum experiment_status {
  draft
  active
  paused
  completed
}

Table experiment {
  id integer [pk, increment]
  nudge_definition_id integer [ref: > nudge_definition.id]
  name varchar
  description text
  start_date timestamp
  end_date timestamp
  status experiment_status
  
  Note: "Manages A/B tests or Holdout tests."
}

Table experiment_group {
  id integer [pk, increment]
  experiment_id integer [ref: > experiment.id]
  name varchar [note: "e.g. 'Control', 'Variant A'"]
  allocation_percent decimal [note: "Percentage of traffic (0-100)"]
  is_control boolean [default: false, note: "If true, users in this group receive NO message (Holdout)"]
  
  Note: "The buckets for the experiment."
}

// -----------------------------------------------------------------------------
// MODULE 3: PROMPT HANDLING (Orchestration & Queue)
// -----------------------------------------------------------------------------

Enum prompt_status {
  pending [note: "Created but not yet processed"]
  scheduled [note: "Waiting for scheduled_at time"]
  queued [note: "Ready to send, waiting for dispatcher"]
  sent
  failed
  expired [note: "Validity period passed before sending"]
  skipped_consent [note: "User opted out"]
  skipped_frequency [note: "User received too many messages"]
  cancelled_completed [note: "User performed the action before nudge was sent"]
  control_group [note: "User selected for Control Group (Holdout). Message suppressed."]
}

Enum prompt_source {
  campaign_engine [note: "Generated via Segment/Campaign"]
  automated_algo [note: "Triggered by external events/doctor comments"]
  manual_override
}

// The core operational table (The "Queue")
Table prompt_queue {
  id uuid [pk]
  person_id uuid [ref: > master_person.id]
  nudge_definition_id integer [ref: > nudge_definition.id]
  nudge_step_id integer [ref: > nudge_step.id, note: "Which step of the workflow is this?"]
  campaign_id integer [ref: > campaign.id, note: "Nullable, if from algo"]
  experiment_group_id integer [ref: > experiment_group.id, note: "Nullable. Tracks A/B test assignment."]
  clinical_recommendation_id uuid [ref: > clinical_recommendation.id, note: "Nullable. If triggered by an event, links to the source signal."]
  
  // Execution details
  source prompt_source
  status prompt_status
  channel channel_type
  
  // Timing
  created_at timestamp [default: `now()`]
  scheduled_for timestamp [note: "When it SHOULD be sent"]
  expires_at timestamp [note: "Do not send after this date"]
  sent_at timestamp
  
  // Payload
  context_data jsonb [note: "Dynamic data for the template (e.g., doctor name, date)"]
  
  Note: "The unified stream of all prompts waiting to be sent or history of sent items."
}

// -----------------------------------------------------------------------------
// MODULE 4: GOVERNANCE & FEEDBACK (Frequency & Logic)
// -----------------------------------------------------------------------------

Table frequency_cap_policy {
  id integer [pk]
  channel channel_type [note: "Nullable = Global cap"]
  category nudge_category [note: "Nullable = All categories"]
  max_messages integer
  time_window interval [note: "e.g., '7 days'"]
  
  Note: "Rules to prevent spamming. Ex: Max 1 Marketing email per 7 days."
}

// -----------------------------------------------------------------------------
// MODULE 5: ACTION TRACKING (Closing the Loop)
// -----------------------------------------------------------------------------

// Feedback loop (Interaction with the Nudge itself)
Table interaction_log {
  id uuid [pk]
  prompt_queue_id uuid [ref: > prompt_queue.id]
  event_type varchar [note: "opened, clicked, converted"]
  occurred_at timestamp
  
  Note: "Tracks effectiveness (Open Rate, Click Rate). Actual 'Health Success' is computed via the linked Goal Segment."
}

// -----------------------------------------------------------------------------
// RELATIONSHIPS & GROUPS
// -----------------------------------------------------------------------------

TableGroup Creation_Module {
  segment
  segment_criteria
  campaign
  nudge_definition
  nudge_step
  message_template
  experiment
  experiment_group
  nudge_data_source
  template_variable
}

TableGroup Handling_Module {
  prompt_queue
  channel_consent
  frequency_cap_policy
  interaction_log
}

TableGroup External_Data {
  clinical_diagnosis
  lab_result
  medication_prescription
  insurance_coverage
  insurance_claim
  claim_line_item
  hospital_encounter
  vaccination_record
  appointment_history
  risk_score
  social_determinants
  clinical_recommendation
}
